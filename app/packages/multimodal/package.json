{
    "name": "@fiftyone/multimodal",
    "version": "0.0.0",
    "private": true,
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": "./src/index.ts",
        "./query": "./src/query/index.ts",
        "./query/bytes": "./src/query/bytes/index.ts",
        "./query/decode": "./src/query/decode/index.ts",
        "./decoders": "./src/decoders/index.ts",
        "./temporal-tags": "./src/temporal-tags/index.ts",
        "./inject": "./src/inject/index.ts",
        "./adapters/mcap": "./src/adapters/mcap/index.ts",
        "./schemas/v1": "./src/schemas/v1/index.ts",
        "./visualization": "./src/visualization/index.ts",
        "./visualization/panels/image": "./src/visualization/panels/image.tsx",
        "./visualization/panels/point-cloud": "./src/visualization/panels/point-cloud.tsx"
    },
    "typesVersions": {
        "*": {
            "decoders": [
                "src/decoders/index.ts"
            ],
            "temporal-tags": [
                "src/temporal-tags/index.ts"
            ],
            "query": [
                "src/query/index.ts"
            ],
            "query/bytes": [
                "src/query/bytes/index.ts"
            ],
            "query/decode": [
                "src/query/decode/index.ts"
            ],
            "inject": [
                "src/inject/index.ts"
            ],
            "adapters/mcap": [
                "src/adapters/mcap/index.ts"
            ],
            "schemas/v1": [
                "src/schemas/v1/index.ts"
            ],
            "visualization": [
                "src/visualization/index.ts"
            ],
            "visualization/panels/image": [
                "src/visualization/panels/image.tsx"
            ],
            "visualization/panels/point-cloud": [
                "src/visualization/panels/point-cloud.tsx"
            ]
        }
    },
    "scripts": {
        "lint": "yarn check",
        "check": "yarn check:lint && yarn check:deps && yarn check:types",
        "check:types": "node ./scripts/check-types.mjs",
        "check:lint": "node ./scripts/check-lint.mjs",
        "check:deps": "node ./scripts/check-deps.mjs"
    },
    "dependencies": {
        "@bufbuild/protobuf": "^2.11.0",
        "@fiftyone/components": "*",
        "@fiftyone/plugins": "*",
        "@fiftyone/state": "*",
        "@fiftyone/tiling": "*",
        "@fiftyone/utilities": "*",
        "@mcap/core": "^2.2.1",
        "@mcap/support": "^1.1.0",
        "@react-three/drei": "9.105.4",
        "@react-three/fiber": "^8.18.0",
        "@voxel51/voodo": "^0.0.34",
        "buffer": "^6.0.3",
        "lru-cache": "^11.0.1",
        "protobufjs": "^7.6.3",
        "three": "^0.182.0"
    },
    "devDependencies": {
        "@types/three": "^0.182.0"
    }
}
