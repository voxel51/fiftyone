{
    "name": "@fiftyone/fiftyone",
    "version": "0.0.0",
    "productName": "FiftyOne",
    "license": "Apache-2.0",
    "private": true,
    "main": "index.js",
    "scripts": {
        "build": "yarn check:strict && yarn workspace @fiftyone/app build",
        "build:win32": "yarn check:strict && yarn workspace @fiftyone/app build:win32",
        "check:strict": "echo 'Running strict lint checks...' && yarn workspace @fiftyone/multimodal check",
        "check": "yarn workspace @fiftyone/app check && yarn workspace @fiftyone/spotlight check && yarn workspace @fiftyone/multimodal check",
        "typecheck": "tsc --noEmit -p tsconfig.check.json",
        "typecheck:error-count": "yarn typecheck | grep -c \"error TS\"",
        "compile": "yarn relay-compiler",
        "dev": "yarn workspace @fiftyone/app dev",
        "dev:py": "python ../fiftyone/server/main.py",
        "dev:wpy": "concurrently -k yarn:dev yarn:dev:py",
        "doc": "./gen-docs.sh",
        "lint:prettify": "prettier --config ../.prettierrc.js --ignore-path ../.prettierignore  --write \"packages/**/*.(ts|js|jsx|tsx|json|css|scss)\"",
        "start": "yarn workspace @fiftyone/app start",
        "test": "yarn vitest run --no-coverage",
        "test:coverage": "yarn vitest run --coverage",
        "test-ui": "yarn vitest --ui --coverage",
        "gen:schema": "strawberry export-schema fiftyone.server.app:schema > schema.graphql"
    },
    "devDependencies": {
        "@bufbuild/protoc-gen-es": "^2.11.0",
        "@testing-library/react": "latest",
        "@types/colormap": "^2",
        "@types/react-plotly.js": "^2.6.3",
        "@typescript-eslint/eslint-plugin": "^5.44.0",
        "@typescript-eslint/parser": "^5.44.0",
        "@vitest/coverage-v8": "^3.0.8",
        "@vitest/ui": "^2.0.5",
        "concurrently": "^7.2.1",
        "dependency-cruiser": "^16.10.4",
        "eslint": "^8.28.0",
        "eslint-config-prettier": "^8.5.0",
        "eslint-plugin-only-warn": "^1.0.3",
        "eslint-plugin-prettier": "^4.2.1",
        "eslint-plugin-react": "^7.31.11",
        "eslint-plugin-react-hooks": "^4.6.0",
        "jsdom": "^20.0.2",
        "prettier": "^2.8.0",
        "relay-compiler": "^14.1.0",
        "relay-runtime": "^14.1.0",
        "typedoc": "^0.23.21",
        "typescript": "^4.9.5",
        "typescript-plugin-css-modules": "^5.0.2",
        "vite": "^7.3.2",
        "vite-plugin-eslint": "^1.8.1",
        "vite-plugin-relay": "^2.0.0",
        "vite-plugin-wasm": "^3.6.0",
        "vitest": "^3.0.8"
    },
    "workspaces": [
        "packages/*"
    ],
    "packageManager": "yarn@4.9.1+sha512.f95ce356460e05be48d66401c1ae64ef84d163dd689964962c6888a9810865e39097a5e9de748876c2e0bf89b232d583c33982773e9903ae7a76257270986538",
    "dependencies": {
        "@rjsf/core": "^6.0.2",
        "@rjsf/mui": "^6.0.2",
        "@rjsf/utils": "^6.0.2",
        "@rjsf/validator-ajv8": "^6.0.2",
        "colormap": "^2.3.2",
        "pixi-viewport": "^6.0.3",
        "react-player": "^2.16.0",
        "react-plotly.js": "^2.6.0"
    },
    "resolutions": {
        "@voxel51/voodo": "^0.0.34",
        "brace-expansion": "^5.0.6",
        "three-stdlib": "^2.36.1",
        "@types/react": "18.2.0",
        "minimatch": "9.0.7",
        "protobufjs": "^7.6.0"
    }
}
