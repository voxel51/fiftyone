{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": ["config:recommended"],
    "baseBranches": ["develop"],
    "gitAuthor": "voxel51-bot <bot@voxel51.com>",
    "rangeStrategy": "widen",
    "prConcurrentLimit": 5,
    "labels": ["dependencies"],
    "enabledManagers": ["pip_requirements", "pip_setup", "github-actions"],
    "ignoreDeps": [
        "pymongo",
        "motor",
        "mongoengine",
        "fiftyone-brain",
        "fiftyone-db",
        "voxel51-eta"
    ],
    "packageRules": [
        {
            "description": "pydicom 3 drops Python 3.9 and changes APIs we rely on",
            "matchPackageNames": ["pydicom"],
            "allowedVersions": "<3"
        },
        {
            "matchManagers": ["pip_requirements", "pip_setup"],
            "groupName": "stable-python-packages",
            "addLabels": ["python"]
        },
        {
            "matchManagers": ["github-actions"],
            "groupName": "github-actions",
            "addLabels": ["github-actions"]
        }
    ],
    "vulnerabilityAlerts": {
        "enabled": true,
        "labels": ["dependencies", "security"]
    },
    "osvVulnerabilityAlerts": true
}
